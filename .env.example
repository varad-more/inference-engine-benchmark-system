# =============================================================================
# .env.example — Copy to .env and fill in your values
#
#   cp .env.example .env
#   # Edit .env — it is gitignored
# =============================================================================

# ---------------------------------------------------------------------------
# HuggingFace Hub token
# Required only for gated models (e.g. Llama 3, Mistral).
# Qwen/Qwen2.5-1.5B-Instruct is public and does NOT require a token.
# Get yours at: https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HUGGING_FACE_HUB_TOKEN=

# ---------------------------------------------------------------------------
# Engine host overrides (for distributed / AWS multi-instance deployments)
# Leave as defaults for local Docker Compose.
# ---------------------------------------------------------------------------
VLLM_HOST=localhost
VLLM_PORT=8000

SGLANG_HOST=localhost
SGLANG_PORT=8001

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
RESULTS_DIR=results
